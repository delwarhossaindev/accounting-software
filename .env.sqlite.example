# SQLite configuration snippet
# Copy these DB_* lines into your .env file to use SQLite
# IMPORTANT: Leave DB_DATABASE empty (or remove the line entirely),
# otherwise Laravel will try to open a file with that name.

DB_CONNECTION=sqlite
DB_DATABASE=
DB_FOREIGN_KEYS=true

# Notes:
# 1. Ensure file `database/database.sqlite` exists (empty file is fine)
#    On Windows: type nul > database\database.sqlite
#    On Linux/Mac: touch database/database.sqlite
#
# 2. Run: php artisan migrate:fresh --seed
