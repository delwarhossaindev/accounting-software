APP_NAME="Accounting Software"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================================
# DATABASE — Choose ONE of the two options below
# ==========================================================

# --- Option 1: MySQL / MariaDB (default) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=accounting_db
DB_USERNAME=root
DB_PASSWORD=

# --- Option 2: SQLite (simple, zero-setup) ---
# To use SQLite instead:
#   1. Comment out the MySQL block above
#   2. Uncomment the two lines below
#   3. Ensure `database/database.sqlite` file exists (empty file is fine)
#   4. Run: php artisan migrate:fresh --seed
#
# DB_CONNECTION=sqlite
# DB_FOREIGN_KEYS=true
# DB_DATABASE must be omitted or set to absolute path for SQLite.
# Laravel will automatically use database/database.sqlite if DB_DATABASE is not set.

# ==========================================================

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================================
# MAIL — For sending invoices to customers
# ==========================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
